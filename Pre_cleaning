/* ride_id is a primary key hence we need to check for consistencies in length */
SELECT LENGTH(ride_id), count(*)
FROM `plated-dryad-448619-k8.Cyclistic.Cyclistic_Combined_Table`
GROUP BY LENGTH(ride_id);

SELECT COUNT (DISTINCT ride_id)
FROM `plated-dryad-448619-k8.Cyclistic.Cyclistic_Combined_Table`;
/* Each ride_id string is 16 digits */
/* There are 5,860,568 ride IDs in total, of which 5,860357 are unique and 211 are duplicates */

